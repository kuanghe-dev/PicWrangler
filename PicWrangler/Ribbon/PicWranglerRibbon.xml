<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui"
          onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab idMso="TabAddIns">
        <group id="grpPicWrangler" label="PicWrangler: Batch Manipulate Pictures">

          <!-- Preset dropdown (normal, top of first column) -->
          <dropDown id="ddPreset" showLabel="false"
                    getItemCount="ddPreset_GetItemCount"
                    getItemLabel="ddPreset_GetItemLabel"
                    getItemID="ddPreset_GetItemID"
                    getSelectedItemIndex="ddPreset_GetSelectedItemIndex"
                    onAction="ddPreset_SelectionChanged" />

          <!-- Set Preset: large button immediately right of dropdown -->
          <button id="btnSetPreset" label="Set Preset" size="large"
                  imageMso="FileSave"
                  onAction="btnSetPreset_Click" />

          <separator id="sep1" />

          <!-- Apply actions: large buttons, then checkboxes stacked beside them -->
          <button id="btnApply" label="Apply" size="large"
                  imageMso="FormatPainter"
                  onAction="btnApply_Click" />
          <button id="btnApplyToSlides" label="Apply to Slides" size="large"
                  imageMso="GroupSmartArtQuickStyles"
                  onAction="btnApplyToSlides_Click" />
          <checkBox id="chkCrop"     label="Crop"
                    getPressed="chkCrop_GetPressed"
                    onAction="chkCrop_Toggle" />
          <checkBox id="chkSize"     label="Size"
                    getPressed="chkSize_GetPressed"
                    onAction="chkSize_Toggle" />
          <checkBox id="chkPosition" label="Position"
                    getPressed="chkPosition_GetPressed"
                    onAction="chkPosition_Toggle" />

          <separator id="sep2" />

          <!-- Bulk Insert (stub) -->
          <button id="btnBulkInsert" label="Bulk Insert" size="large"
                  imageMso="OmsSlideInsert"
                  onAction="btnBulkInsert_Click" />
          <checkBox id="chkApplyPreset" label="Apply Preset" enabled="false"
                    getPressed="chkApplyPreset_GetPressed"
                    onAction="chkApplyPreset_Toggle" />
          <checkBox id="chkAddTitle"    label="Add Title"    enabled="false"
                    getPressed="chkAddTitle_GetPressed"
                    onAction="chkAddTitle_Toggle" />
          <checkBox id="chkAddNotes"    label="Add Notes"    enabled="false"
                    getPressed="chkAddNotes_GetPressed"
                    onAction="chkAddNotes_Toggle" />

          <separator id="sep3" />

          <button id="btnHelp" label="Help" size="large"
                  imageMso="Help"
                  onAction="btnHelp_Click" />

        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
